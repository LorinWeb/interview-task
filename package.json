{
  "name": "interview-task",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n app,worker -c blue,magenta \"tsx watch server.ts\" \"tsx watch src/server/worker-entry.ts\"",
    "dev:e2e": "PORT=3100 DB_SOURCE=local LOCAL_DB_PATH=.tmp/e2e/app.db UPLOADS_DIR=.tmp/e2e/uploads concurrently -k -n app,worker -c blue,magenta \"tsx server.ts\" \"tsx src/server/worker-entry.ts\"",
    "build": "vite build",
    "start": "NODE_ENV=production concurrently -k -n app,worker -c blue,magenta \"tsx server.ts\" \"tsx src/server/worker-entry.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "worker": "tsx src/server/worker-entry.ts"
  },
  "dependencies": {
    "better-sqlite3": "12.8.0",
    "concurrently": "9.2.1",
    "csv-parse": "6.2.1",
    "express": "5.1.0",
    "lucide-react": "0.546.0",
    "motion": "12.23.24",
    "multer": "2.0.2",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@tailwindcss/vite": "4.1.16",
    "@types/better-sqlite3": "7.6.13",
    "@types/express": "5.0.3",
    "@types/multer": "2.0.0",
    "@types/node": "25.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/supertest": "6.0.3",
    "@vitejs/plugin-react": "5.0.4",
    "@vitest/coverage-v8": "4.1.2",
    "supertest": "7.1.4",
    "tailwindcss": "4.1.16",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite": "7.1.9",
    "vitest": "4.1.2"
  }
}
